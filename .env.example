# General configuration
APP_PORT=3000
APP_ENV=development

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=database

# Microservice A configuration
MICROSERVICE_A_URL=http://localhost:5001
MICROSERVICE_A_API_KEY=your_api_key

# Microservice B configuration
MICROSERVICE_B_URL=http://localhost:5002
MICROSERVICE_B_API_KEY=your_api_key

# Other microservices can be added here in the same format
